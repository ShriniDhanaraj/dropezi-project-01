{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "*.md",
      ".git/**",
      "node_modules/**",
      "index.html",
      "index-redesign.html",
      "project03-live-backup-pre-faq-chatbot.html",
      "DROPeZi-Business-Strategy/**"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" }
        ]
      },
      {
        "source": "**/*.mp4",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(webp|jpg|jpeg|png|svg|gif|ico|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/nri", "destination": "/nri-prototype.html" },
      { "source": "**", "destination": "/project03-live.html" }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
